# Gemini API Key (for secretary helper features, optional if not using Gemini features yet)
GEMINI_API_KEY=your-gemini-api-key

# Firebase Settings
# The bot expects a serviceAccountKey.json in the same folder, but you can also configure project ID:
FIREBASE_PROJECT_ID=tasks-b9e9e

# WhatsApp Target Configuration
# The name of the group chat to send reminders to (e.g. 'גדוד 402')
WHATSAPP_GROUP_NAME=גדוד 402

# Optionally specify JID if known (e.g. 120363028374928374@g.us)
WHATSAPP_GROUP_ID=
